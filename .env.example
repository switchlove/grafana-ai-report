# Grafana instance URL and datasource
GRAFANA_URL=http://localhost:4000
DATA_SOURCE_UID=your_datasource_uid_here

# Grafana service account token (Settings → Service Accounts)
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Directory where AI reports are saved
REPORT_DIR=/var/log/grafana_ai

# Optional: Discord webhook URL for post-run notifications
# Create one at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Optional: Custom Discord emoji IDs for JIRA-style severity icons
# Get IDs by typing \:EmojiName: in a Discord message (shows the raw <:Name:id> format)
DISCORD_EMOJI_HIGHEST=
DISCORD_EMOJI_HIGH=
DISCORD_EMOJI_MEDIUM=
DISCORD_EMOJI_LOW=
DISCORD_EMOJI_LOWEST=
